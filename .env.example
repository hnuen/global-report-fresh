# ══════════════════════════════════════════════════════════════════════════════
# THE GLOBAL REPORT — Environment Variables
# Copy this to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Providers (Anthropic) ─────────────────────────────────────────────────
# Primary key — always required
ANTHROPIC_API_KEY=sk-ant-...

# Secondary key — optional. Used automatically when primary hits daily limit.
ANTHROPIC_API_KEY_2=sk-ant-...

# Tertiary key — optional. Used when both primary and secondary hit limits.
ANTHROPIC_API_KEY_3=sk-ant-...

# Daily request limits per key (0 = unlimited / don't track)
# Example: set to 20 to leave headroom for other uses of that key
ANTHROPIC_PRIMARY_DAILY_LIMIT=0
ANTHROPIC_SECONDARY_DAILY_LIMIT=0
ANTHROPIC_TERTIARY_DAILY_LIMIT=0

# ── Storage: Vercel KV ────────────────────────────────────────────────────────
# Auto-populated when you add KV storage in Vercel dashboard
# Copy from: Vercel Dashboard → Storage → KV → .env.local tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Storage: Upstash Redis ────────────────────────────────────────────────────
# Free 10,000 req/day — works on ANY platform (Vercel, Railway, Cloudflare, local)
# Get from: https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Security ──────────────────────────────────────────────────────────────────
# Any random string — used to authenticate cron and refresh calls
# Set the same value in GitHub Actions secrets and Vercel/Railway env vars
CRON_SECRET=your-random-secret-here

# Also add as NEXT_PUBLIC_ so the browser refresh button can send it:
NEXT_PUBLIC_CRON_SECRET=your-random-secret-here

# ══════════════════════════════════════════════════════════════════════════════
# PLATFORM NOTES:
#
# VERCEL:      Set via Vercel Dashboard → Settings → Environment Variables
#              OR: vercel env add VARIABLE_NAME
#
# RAILWAY:     Set via Railway Dashboard → Variables tab
#              OR: railway variables set VARIABLE_NAME=value
#
# CLOUDFLARE:  Secrets: npx wrangler secret put VARIABLE_NAME
#              Plain:   add to wrangler.toml [vars] section
#
# GITHUB:      Secrets: repo → Settings → Secrets → Actions → New secret
#              (for CRON_SECRET and APP_URL only)
# ══════════════════════════════════════════════════════════════════════════════

# ── SMS Alerts (Twilio) ────────────────────────────────────────────────────────
# Sign up free at twilio.com — free trial gives ~$15 credit (~1000 SMS)
# After trial: ~$0.0079/SMS in US, ~$0.05/SMS internationally

# From Twilio Console dashboard:
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (buy one in Twilio console, ~$1/month)
TWILIO_FROM_NUMBER=+14155551234

# Who to text — comma-separated, include country code
# Example: ALERT_TO_NUMBERS=+14155559999,+447700900000,+6591234567
ALERT_TO_NUMBERS=+1XXXXXXXXXX

# Your deployed app URL (used as link in SMS)
APP_URL=https://your-app.vercel.app

# ── Alert tuning ──────────────────────────────────────────────────────────────
# Score threshold 0-100. Default 75. Lower = more alerts, higher = fewer.
# Suggested ranges:
#   90+ = only truly breaking news (new SDN designations, enforcement actions)
#   75  = important but not urgent (policy changes, major fines)
#   60  = broader monitoring (any high-impact article)
ALERT_SCORE_THRESHOLD=75

# Additional keywords that boost article score (+15 each)
# Useful for watching specific entities, countries, or topics
# Example: ALERT_KEYWORDS=Huawei,Bank of China,DPRK,Myanmar
ALERT_KEYWORDS=

# Sections to watch (comma-separated, or "all")
# Options: sanctions,economics,religion,occ,penalties,bis
ALERT_SECTIONS=all

# Max SMS sent per monitor run (prevents spam bursts). Default 3.
ALERT_MAX_PER_RUN=3

# How long (minutes) before the same headline can trigger another alert.
# Default 360 (6 hours). Set higher to reduce repeat texts.
ALERT_COOLDOWN_MINUTES=360

# ── Notification Channels ──────────────────────────────────────────────────────
# Configure any combination. System tries in order, falls back automatically.
# Order: NOTIFIER_ORDER=telegram,ntfy,discord,email-sms,twilio (default)
# Strategy: NOTIFIER_STRATEGY=first-success (default) or "all"

# ── 1. Telegram Bot (FREE — recommended) ──────────────────────────────────────
# Setup: open Telegram → @BotFather → /newbot → get token
# Get chat ID: message your bot → api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:ABC-DEFghijklmno...
TELEGRAM_CHAT_IDS=123456789                  # comma-separated for multiple chats
TELEGRAM_DIGEST_MODE=false                   # true = one summary msg per run

# ── 2. Ntfy.sh (FREE — simplest, no account) ──────────────────────────────────
# Setup: install ntfy app → pick a topic name → subscribe
# Topic is public by default — make it hard to guess!
NTFY_TOPIC=globalreport-yourname-xyz123
NTFY_SERVER=https://ntfy.sh                  # or your self-hosted instance
NTFY_TOKEN=                                  # optional, for private topics

# ── 3. Discord Webhook (FREE) ─────────────────────────────────────────────────
# Setup: Discord → channel settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/...
DISCORD_MENTION_ROLE=                        # optional role ID to ping
DISCORD_MENTION_USER=                        # optional user ID to ping

# ── 4. Email-to-SMS (FREE via carrier gateway) ────────────────────────────────
# No extra account — uses your Gmail/Outlook to text carrier gateway addresses
# Gmail: enable 2FA → myaccount.google.com/apppasswords → create app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx              # Gmail app password (16 chars)
EMAIL_FROM=your@gmail.com
EMAIL_SMS_RECIPIENTS=2125550100@tmomail.net,4155550199@vtext.com
# Carrier gateways: AT&T=@txt.att.net, T-Mobile=@tmomail.net, Verizon=@vtext.com

# ── 5. Twilio SMS (paid fallback, ~$0.008/SMS US) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+14155551234
ALERT_TO_NUMBERS=+14155559999              # comma-separated

# ── Alert tuning (shared across all channels) ─────────────────────────────────
ALERT_SCORE_THRESHOLD=75                   # 0-100, default 75
ALERT_MAX_PER_RUN=3                        # max alerts per monitor run
ALERT_COOLDOWN_MINUTES=360                 # 6 hours between same-headline alerts
ALERT_KEYWORDS=                            # extra keywords, comma-separated
ALERT_SECTIONS=all                         # or: sanctions,economics,bis
NOTIFIER_ORDER=telegram,ntfy,discord,email-sms,twilio
NOTIFIER_STRATEGY=first-success            # or "all"

# ── Google Gemini (FREE — 1,500 requests/day, no credit card) ─────────────────
# Get your key at: aistudio.google.com → Get API key → Create API key
# Used as fallback when Anthropic credits run out
GEMINI_API_KEY=AIza...
GEMINI_DAILY_LIMIT=1500
GEMINI_MODEL=gemini-2.0-flash
